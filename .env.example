# Copy to .env and fill in your key.
ANTHROPIC_API_KEY=sk-ant-...

# Model that drives the bot. sonnet = fast/cheap control loop; opus = smarter.
CLAUDE_MODEL=claude-sonnet-4-6

# AI backend. Leave unset for the Anthropic API (default). Options:
#   ollama     — drive the bot with a local Ollama model (no Anthropic key needed)
#   standalone — no AI; you type tool commands yourself
# BOT_MODE=ollama

# Ollama settings (used only when BOT_MODE=ollama). The model must support tool
# calling (e.g. llama3.1, qwen2.5, qwen2.5-coder, mistral-nemo). Pull it first:
#   ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Safety: which player's chat commands the bot obeys. Defaults to MC_OWNER below,
# so bots never act on each other's chat (that loop burns API tokens fast). Set to
# * to let anyone command the bot.
# BOT_COMMANDER=kaikdidk

# Safety: max AI calls per minute per bot (circuit breaker against runaway loops).
AI_MAX_CALLS_PER_MIN=30

# Require a [name]/[all] prefix on chat commands. Off by default — plain chat from
# the commander is obeyed; [name]/[all] still works to target a specific bot when
# several are running. Set to true to require explicit addressing.
# BOT_REQUIRE_NAME=true

# The bot's own player name, and the default commander/owner.
MC_OWNER=kaikdidk

# Minecraft server connection. version MUST match the server you run.
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.21.4
MC_USERNAME=ClaudeBot

# Web viewer to watch the bot in a browser (no Minecraft client needed).
ENABLE_VIEWER=true
VIEWER_PORT=3007

# RAM given to the local server.
MC_MEMORY=2G
