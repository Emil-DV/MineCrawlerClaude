{
  "name": "minecrawler-claude",
  "version": "0.1.0",
  "description": "Claude controls a Minecraft character via a Mineflayer bot and the Anthropic API",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "server:setup": "node scripts/setup-server.mjs",
    "server": "node scripts/start-server.mjs",
    "test:commands": "node scripts/test-commands.js",
    "server:start": "bash scripts/start-server.sh",
    "server:stop": "bash scripts/stop-server.sh",
    "ollama:start": "bash scripts/start-ollama.sh",
    "ollama:stop": "bash scripts/stop-ollama.sh",
    "worlds": "node scripts/list-worlds.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "minecraft-data": "^3.78.0",
    "mineflayer": "^4.37.0",
    "mineflayer-pathfinder": "^2.4.5"
  },
  "optionalDependencies": {
    "prismarine-viewer": "^1.33.0"
  }
}
